/**
 * Real package-based pricing database for grocery stores.
 *
 * Each entry maps a canonical ingredient key to actual packages sold at each store.
 * Prices reflect real 2025-2026 shelf prices (rounded to nearest cent).
 * When a store doesn't carry an item, it falls back to a default.
 */

export interface PackageEntry {
  /** Weight/volume in the item's base unit (grams for solids, ml for liquids, "count" items use count) */
  packageSize: number;
  /** Base unit: "g", "ml", or "count" */
  unit: string;
  /** Shelf price in USD */
  price: number;
  /** Human-readable label, e.g. "3 lb bag, boneless skinless" */
  label: string;
}

export type StoreKey =
  | "walmart"
  | "aldi"
  | "costco"
  | "sams_club"
  | "target"
  | "food_lion"
  | "trader_joes"
  | "harris_teeter"
  | "publix"
  | "whole_foods";

const SUPPORTED_STORES: StoreKey[] = [
  "walmart",
  "aldi",
  "costco",
  "sams_club",
  "target",
  "food_lion",
  "trader_joes",
  "harris_teeter",
  "publix",
  "whole_foods",
];

/**
 * Master package database.
 * Key = canonical ingredient (lowercase).
 * Value = store → package info.
 *
 * Prices sourced from store websites / Instacart as of early 2026.
 * Updated periodically — not live-scraped.
 */
