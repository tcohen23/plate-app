  "soy": "soy sauce",
  "tamari": "soy sauce",
  "sriracha": "hot sauce",
  "canned black beans": "beans",
  "black beans": "beans",
  "chickpeas": "beans",
  "lentils": "beans",
  "canned chickpeas": "beans",
  "kidney beans": "beans",
  "diced tomatoes": "canned tomatoes",
  "crushed tomatoes": "canned tomatoes",
  "tomato sauce": "canned tomatoes",
  "tomato paste": "canned tomatoes",
  "marinara": "canned tomatoes",
  "pasta sauce": "canned tomatoes",
};

/**
 * Given a raw ingredient name from a meal, resolve the canonical package key.
 */
export function resolveIngredientKey(rawName: string): string | null {
  const lower = rawName.toLowerCase().trim();

  // 1. Direct match
  if (PACKAGE_DB[lower]) return lower;

  // 2. Alias match
  if (ALIASES[lower]) return ALIASES[lower];

  // 3. Substring match against canonical keys (greedy, longest first)
  for (const key of CANONICAL_KEYS) {
    if (lower.includes(key)) return key;
  }

  // 4. Substring match against alias keys
  const aliasKeys = Object.keys(ALIASES).sort((a, b) => b.length - a.length);
  for (const alias of aliasKeys) {
    if (lower.includes(alias)) return ALIASES[alias];
  }

  return null;
}

/**
 * Get the package entry for a given ingredient at a given store.
 * Falls back to walmart if the store doesn't have the item.
 */
export function getPackageForStore(
  canonicalKey: string,
  storeKey: StoreKey
): PackageEntry | null {
  const itemEntry = PACKAGE_DB[canonicalKey];
  if (!itemEntry) return null;
  return itemEntry[storeKey] || itemEntry["walmart"] || null;
}

/**
 * Calculate how many whole packages are needed, and the total cost.
 */
export function calculatePackageCost(
  neededAmount: number,
  neededUnit: string,
  pkg: PackageEntry
): { packages: number; totalPrice: number } {
  // Normalize units to match package unit
  let normalizedNeeded = neededAmount;

  // Handle unit conversions
  const needLower = neededUnit.toLowerCase();
  if (pkg.unit === "g") {
    if (needLower === "oz") normalizedNeeded = neededAmount * 28.35;
    else if (needLower === "lb" || needLower === "lbs") normalizedNeeded = neededAmount * 453.6;
    else if (needLower === "kg") normalizedNeeded = neededAmount * 1000;
    // else assume grams
  } else if (pkg.unit === "ml") {
    if (needLower === "oz" || needLower === "fl oz") normalizedNeeded = neededAmount * 29.57;
    else if (needLower === "cup" || needLower === "cups") normalizedNeeded = neededAmount * 236.6;
    else if (needLower === "tbsp") normalizedNeeded = neededAmount * 14.79;
    else if (needLower === "tsp") normalizedNeeded = neededAmount * 4.93;
    else if (needLower === "l" || needLower === "liter") normalizedNeeded = neededAmount * 1000;
    // else assume ml
  }
  // "count" items: no conversion needed

  const packages = Math.max(1, Math.ceil(normalizedNeeded / pkg.packageSize));
  let totalPrice = Math.round(packages * pkg.price * 100) / 100;

  // Sanity cap: no single ingredient should exceed $25 for a weekly grocery list
  // This prevents absurd prices from unit conversion errors or tiny package sizes
  const SANITY_CAP = 25.00;
  if (totalPrice > SANITY_CAP) {
    totalPrice = SANITY_CAP;
  }

  return { packages, totalPrice };
}

/**
 * Default price estimate for items not in our database.
 * Uses category-based average pricing.
 */
export function getDefaultPackagePrice(
  category: string,
  storeKey: StoreKey
): number {
  const categoryDefaults: Record<string, number> = {
    "Proteins": 6.99,
    "Carbs & Grains": 2.99,
    "Produce": 2.49,
    "Fats & Dairy": 3.99,
    "Pantry": 2.99,
    "Other": 3.49,
  };

  const basePrice = categoryDefaults[category] || 3.49;

  // Apply a simple store multiplier for unknown items
  const storeMultipliers: Record<StoreKey, number> = {
    walmart: 0.90,
    aldi: 0.82,
    costco: 0.85,
    sams_club: 0.87,
    target: 1.00,
    food_lion: 0.92,
    trader_joes: 1.00,
    harris_teeter: 1.08,
    publix: 1.05,
    whole_foods: 1.30,
  };

  return Math.round(basePrice * (storeMultipliers[storeKey] || 1.0) * 100) / 100;
}

export { SUPPORTED_STORES, PACKAGE_DB };
